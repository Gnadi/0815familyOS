rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // A user may read their own document, or any document belonging to a
    // member of the same family (needed to resolve member display names).
    match /users/{uid} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId != null &&
          uid in get(/databases/$(database)/documents/families/$(
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId
          )).data.memberIds
        )
      );
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Families.
    // Any signed-in user may read a family document — this is required so the
    // "Join by invite code" flow can look the family up by code before the
    // user is a member. The invite code itself is the access secret.
    // Writes are restricted: create must include the caller as a member and
    // creator; members can update freely; a non-member can update only to
    // add themselves to memberIds and nothing else.
    match /families/{familyId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.createdBy == request.auth.uid;

      allow update: if request.auth != null
        && request.auth.uid in resource.data.memberIds;

      // Join: non-member adds exactly themselves, no other field changes.
      allow update: if request.auth != null
        && !(request.auth.uid in resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']);
    }

    // Events belong to a family; only family members may read/write them.
    match /events/{eventId} {
      function familyMembers(fid) {
        return get(/databases/$(database)/documents/families/$(fid)).data.memberIds;
      }
      allow read: if request.auth != null
        && request.auth.uid in familyMembers(resource.data.familyId);
      allow create: if request.auth != null
        && request.auth.uid in familyMembers(request.resource.data.familyId)
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && request.auth.uid in familyMembers(resource.data.familyId);
    }

    // Tasks mirror the events rule: only members of the owning family may
    // read or mutate them, and creation must identify the caller.
    match /tasks/{taskId} {
      function familyMembers(fid) {
        return get(/databases/$(database)/documents/families/$(fid)).data.memberIds;
      }
      allow read: if request.auth != null
        && request.auth.uid in familyMembers(resource.data.familyId);
      allow create: if request.auth != null
        && request.auth.uid in familyMembers(request.resource.data.familyId)
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && request.auth.uid in familyMembers(resource.data.familyId);
    }

    // Gifts: only family members may read or mutate. No userId check on
    // create because gifts have no author field.
    match /gifts/{giftId} {
      function familyMembers(fid) {
        return get(/databases/$(database)/documents/families/$(fid)).data.memberIds;
      }
      allow read: if request.auth != null
        && request.auth.uid in familyMembers(resource.data.familyId);
      allow create: if request.auth != null
        && request.auth.uid in familyMembers(request.resource.data.familyId);
      allow update, delete: if request.auth != null
        && request.auth.uid in familyMembers(resource.data.familyId);
    }

    // Document Vault (documents and trophies). Mirrors the tasks rule.
    match /documents/{documentId} {
      function familyMembers(fid) {
        return get(/databases/$(database)/documents/families/$(fid)).data.memberIds;
      }
      allow read: if request.auth != null
        && request.auth.uid in familyMembers(resource.data.familyId);
      allow create: if request.auth != null
        && request.auth.uid in familyMembers(request.resource.data.familyId)
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && request.auth.uid in familyMembers(resource.data.familyId);
    }

    // Vaccinations: only family members may read or write records.
    // Each record is tied to a kidId (child within the family) and the
    // creating user. Any family member can edit or delete any record so
    // both parents can manage the children's health data together.
    match /vaccinations/{vaccinationId} {
      function familyMembers(fid) {
        return get(/databases/$(database)/documents/families/$(fid)).data.memberIds;
      }
      allow read: if request.auth != null
        && request.auth.uid in familyMembers(resource.data.familyId);
      allow create: if request.auth != null
        && request.auth.uid in familyMembers(request.resource.data.familyId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.kidId is string
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update, delete: if request.auth != null
        && request.auth.uid in familyMembers(resource.data.familyId);
    }
  }
}
